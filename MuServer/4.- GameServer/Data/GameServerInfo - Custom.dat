; Custom Online Lottery Settings
;==================================================
CustomOnlineLotterySwitch = 1
CustomOnlineLotteryText1 = %s sẽ diễn ra sau %d phút.
CustomOnlineLotteryText2 = %s là người chiến thắng trong đợt quay số. Xin chúc mừng!

[GameServerInfo]
;==================================================
; Announce Chaos Mix Settings
; AnnounceChaosMixLevel: 0 ~ 5
;==================================================
AnnounceChaosMix = 1
AnnounceChaosMixLevel = 5
AnnounceChaosMixSuccess = Chúc mừng %s. Vật phẩm %s đã nâng cấp thành công lên cấp +%d.
AnnounceChaosMixFailure = %s rất tiếc! Vật phẩm %s đã thất bại khi nâng lên cấp +%d.

;==================================================
; Custom Arena Settings
;==================================================
CustomArenaSwitch = 1
CustomArenaVictimScoreDecrease = 10
CustomArenaKillerScoreIncrease = 100
CustomArenaText1 = [%s] sẽ đóng trong %d phút.
CustomArenaText2 = [%s] đã đóng.
CustomArenaText3 = [%s] sẽ bắt đầu sau %d phút.
CustomArenaText4 = [%s] đã bắt đầu.
CustomArenaText5 = [%s] đã hoàn thành.
CustomArenaText6 = [%s] %s là người chiến thắng.
CustomArenaText7 = [%s] Bạn đã đạt vị trí thứ %d với %d điểm.
CustomArenaText8 = Bạn không thể vào đấu trường.
CustomArenaText9 = Đấu trường hiện tại chưa mở.
CustomArenaText10 = Vượt quá số lượng người chơi tối đa.
CustomArenaText11 = Bạn phải đạt ít nhất cấp độ %d.
CustomArenaText12 = Bạn phải có cấp độ tối đa là %d.
CustomArenaText13 = Bạn phải đạt ít nhất Master Level %d.
CustomArenaText14 = Bạn phải có Master Level tối đa là %d.
CustomArenaText15 = Bạn phải có ít nhất %d lần Reset.
CustomArenaText16 = Bạn chỉ được có tối đa %d lần Reset.
CustomArenaText17 = Bạn phải có ít nhất %d lần Master Reset.
CustomArenaText18 = Bạn chỉ được có tối đa %d lần Master Reset.
CustomArenaText19 = Lớp nhân vật của bạn không được phép vào đấu trường.

;==================================================
; Custom Mix Expansion
;==================================================
GoblinMixNpc= 238
GoblinMixNpcX= 185
GoblinMixNpcY= 105
GoblinMixNpcMap= 3

;==================================================
; Custom Event Drop Settings
;==================================================
CustomEventDropSwitch = 1
CustomEventDropText1 = [%s] sẽ bắt đầu sau %d phút.
CustomEventDropText2 = [%s] đã bắt đầu.
CustomEventDropText3 = [%s] đã kết thúc.


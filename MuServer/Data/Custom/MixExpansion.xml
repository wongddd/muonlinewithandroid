<!--
[SPN]
Key = clave de registro para identificar el mix
Name = nombre visual para registrar el mix
MixRate = porcentaje de probabilidad de exito
Buy = tipo de monea [0 = zen][1 = coin1][2 = coin2][3 = coin3]
TalismanOfChaos = Index del item que representa un talisman para evitar que el item sea consumido
TalismanOfLuck = Index del item que representa un talisman para incrementar el porcentaje de exito
LuckRate = cantidad de suerte incrementada por cada TalismanOfLuck
MaxTalisman = numero maximo de TalismanOfLuck permitidos

[POR]
Key = chave de registro para identificar o mix
Nome = nome visual para registrar o mix
MixRate = porcentagem de probabilidade de sucesso
Comprar = tipo de moeda [0 = zen][1 = moeda1][2 = moeda2][3 = moeda3]
TalismanOfChaos = Índice do item que representa um talismã para evitar que o item seja consumido
TalismanOfLuck = Índice do item que representa um talismã para aumentar o percentual de sucesso
LuckRate = quantidade de sorte aumentada para cada TalismanOfLuck
MaxTalisman = número máximo de TalismanOfLuck permitido

[ENG]
Key = registry key to identify the mix
Name = visual name to register the mix
MixRate = percentage of probability of success
Money = Money type [0 = zen][1 = coin1][2 = coin2][3 = coin3]
TalismanOfChaos = Index of the item that represents a talisman to prevent the item from being consumed
TalismanOfLuck = Index of the item that represents a talisman to increase the success percentage
LuckRate = amount of luck increased for each TalismanOfLuck
MaxTalisman = maximum number of TalismanOfLuck allowed
-->


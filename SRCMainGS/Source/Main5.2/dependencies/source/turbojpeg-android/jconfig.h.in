/* Android-specific jconfig.h for libjpeg-turbo 3.1.0 */

#define JPEG_LIB_VERSION  62
#define LIBJPEG_TURBO_VERSION  3.1.0
#define LIBJPEG_TURBO_VERSION_NUMBER  3001000

/* Support arithmetic encoding/decoding */
#define C_ARITH_CODING_SUPPORTED 1
#define D_ARITH_CODING_SUPPORTED 1

/* Support in-memory source/destination managers */
#define MEM_SRCDST_SUPPORTED 1

/* Use accelerated SIMD routines when using 8-bit samples */
#if defined(ANDROID) || defined(__ANDROID__)
/* #undef WITH_SIMD */ /* Disabled for initial Android port */
#else
#define WITH_SIMD 1
#endif

#ifndef BITS_IN_JSAMPLE
#define BITS_IN_JSAMPLE  8
#endif

/* Android (Linux/Clang): right shift of signed values is arithmetic, not logical */
/* #undef RIGHT_SHIFT_IS_UNSIGNED */
